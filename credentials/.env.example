# ── App ───────────────────────────────────────────────────────

APP_NAME=Mobile API
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────────

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mobile_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── MongoDB ───────────────────────────────────────────────────

MONGO_URI=mongodb+srv://mongo_user:mongo_password@kankunapaq-db.me4ilfe.mongodb.net/
MONGO_DATABASE=test

# ── Redis ─────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379

# ── Object Storage (Cloudflare R2 / AWS S3) ──────────────────

#OBJECT_STORAGE_PROVIDER=r2
OBJECT_STORAGE_BUCKET=mobile
OBJECT_STORAGE_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
OBJECT_STORAGE_ACCESS_KEY=your_access_key
OBJECT_STORAGE_SECRET_KEY=your_secret_key
OBJECT_STORAGE_REGION=auto

# ── CORS ──────────────────────────────────────────────────────

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://mobile_endpoints.kankunapaq.com

# ── Authentication (JWT) ─────────────────────────────────────

SECRET_KEY=change_this_to_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google Login ──────────────────────────────────────────────

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Seed ──────────────────────────────────────────────────────

SEED_ADMIN_EMAIL=admin@mobileapi.com
SEED_ADMIN_PASSWORD=Admin1234!   # PBKDF2WithHmacSHA256
SEED_ADMIN_DOCUMENT_ID=00000000

# ── LLM ───────────────────────────────────────────────────────
LLM_TYPE="local" # local or cloud
LLM_URL=http://127.0.0.1:9000

LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=xxx
